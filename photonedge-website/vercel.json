{
  "rewrites": [
    { "source": "/products/:slug", "destination": "/product-detail.html?slug=$slug" },
    { "source": "/blog/:slug", "destination": "/blog-post.html?slug=$slug" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
